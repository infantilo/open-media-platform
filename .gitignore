# (1.17) ist zu alt für MXLs vendorten Fabrics-Code (braucht 2.x), lokal
# aus Quellcode vendort wie MXL selbst.
/third_party/libfabric/

# Claude Code lokale Projekt-Settings/Lock-Dateien
/.claude/

# Postgres-Backups (S9, deploy/dev/backup-omp.sh) — enthalten Nutzer-
